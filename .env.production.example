APP_ENV=production
APP_NAME=Ebeveyn Köprüsü
APP_DEFAULT_LOCALE=tr
APP_TIMEZONE=Europe/Istanbul

# Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Keep these out of Flutter builds. Use only for CLI/server secrets.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional providers. Leave mock/empty for first production smoke test.
# Ebeveyn Asistanı kaldırıldı; canlı çıkış için LLM API zorunlu değildir.
TONE_ASSISTANT_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=

REVENUECAT_IOS_API_KEY=
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

FIREBASE_PROJECT_ID=
FCM_SERVER_KEY=

OPEN_BANKING_PROVIDER=
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
OPEN_BANKING_REDIRECT_URI=
OPEN_BANKING_AUTHORIZATION_URL=
OPEN_BANKING_TOKEN_URL=

RTC_PROVIDER=mock
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

DOCUMENTS_BUCKET=documents
PUBLIC_APP_URL=

SENTRY_DSN=
POSTHOG_API_KEY=

APP_STORE_PRIVACY_URL=
APP_STORE_TERMS_URL=
SUPPORT_EMAIL=
